{
  "name": "tradingon",
  "version": "1.0.0",
  "description": "Hyperliquid perpetual futures trading bot for Solana meme tokens",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "npm run build:all",
    "build:api": "nest build -p tsconfig.build.json",
    "build:ui": "webpack --mode production --config webpack.config.js",
    "build:all": "npm run build:ui && npm run build:api",
    "install:all": "npm ci",
    "dev:all": "node scripts/dev-all.js",
    "dev:backend": "nest start --watch",
    "dev:frontend": "webpack serve --mode development --config webpack.config.js --host 0.0.0.0 --port 5173",
    "dev": "npm run dev:frontend",
    "docker:db:up": "docker compose up -d db",
    "format": "prettier --write \"server/**/*.ts\"",
    "start": "nest start",
    "start:api:dev": "npm run dev:backend",
    "start:dev": "npm run dev:backend",
    "start:ui:dev": "npm run dev:frontend",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "prepare:prod": "npm run migration:run && npm run config:seed",
    "deploy:prod": "npm run build:all && npm run prepare:prod",
    "config:seed": "ts-node -r tsconfig-paths/register server/config/seed-app-settings.ts",
    "lint": "eslint \"{server,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d server/config/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run -d server/config/data-source.ts"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^2.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/serve-static": "^4.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "ethers": "^5.7.2",
    "pg": "^8.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "technicalindicators": "^3.1.0",
    "typeorm": "^0.3.17",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.5",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "eslint": "^8.42.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "vite": "^5.4.10",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "server",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
