{
  "name": "tradingon",
  "version": "1.0.0",
  "description": "Hyperliquid perpetual futures trading bot for Solana meme tokens",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "npm run build:all",
    "build:api": "tsc -p server/tsconfig.build.json",
    "build:ui": "vite build",
    "build:all": "npm run build:ui && npm run build:api",
    "typecheck": "npm run typecheck:ui && npm run typecheck:api",
    "typecheck:ui": "tsc --noEmit -p tsconfig.frontend.json",
    "typecheck:api": "tsc --noEmit -p server/tsconfig.json",
    "dev": "npm run dev:frontend",
    "dev:all": "node scripts/dev-all.js",
    "dev:backend": "node scripts/dev-backend.js",
    "dev:frontend": "vite --host 0.0.0.0 --port 5173",
    "docker:db:up": "docker compose up -d db",
    "start": "npm run start:prod",
    "start:api:dev": "npm run dev:backend",
    "start:ui:dev": "npm run dev:frontend",
    "start:prod": "node server/dist/main.js",
    "config:seed": "ts-node -r tsconfig-paths/register server/config/seed-app-settings.ts",
    "test": "jest --runInBand",
    "typeorm": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:run": "npm run typeorm -- migration:run -d server/config/data-source.ts"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^2.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/serve-static": "^4.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "ethers": "^5.7.2",
    "pg": "^8.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "technicalindicators": "^3.1.0",
    "typeorm": "^0.3.17",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.5",
    "@vitejs/plugin-react": "^4.3.3",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "vite": "^5.4.10"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "server",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
